generator client {
  provider = "prisma-client-js"
}

generator client_py {
  provider = "prisma-client-py"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Item {
  id          String   @id @default(uuid())
  title       String
  url         String   @unique
  source      String
  type        String   // "academic" or "industry"
  summary     String
  category    String
  score       Float
  publishedAt DateTime
  createdAt   DateTime @default(now())
}
